    if options.dump_sql and options.from_version is None:
        print(
            "Error: --dump-sql requires --from VERSION so SQL can be generated from an explicit range.",
            file=sys.stderr,
        )
        sys.exit(1)

    config = None
    from_version_supplied = options.from_version is not None

    if options.dump_sql:
        current_version = options.from_version
    else:
        config = config_from_options(options)
        current_version = options.from_version or get_recorded_schema_version(config)

    if current_version is None:
        print(
            "Error: Could not determine current Absurd schema version. "
            "Pass --from VERSION, or install a schema that defines absurd.get_schema_version().",
            file=sys.stderr,
        )
        sys.exit(1)

    migrations = discover_migrations(script_dir, target_version, include_remote=False)
    path = resolve_migration_path(current_version, target_version, migrations)

    needs_remote_retry = path is None or (
        compare_versions(current_version, target_version) < 0 and not path
    )

    if needs_remote_retry:
        # Local/bundled migrations might not be complete (for example when
        # running a standalone absurdctl without migration files). Fall back to
        # GitHub to discover additional migrations.
        migrations = discover_migrations(
            script_dir,
            target_version,
            include_remote=True,
        )
        path = resolve_migration_path(current_version, target_version, migrations)

    if path is None:
        print(
            f"Error: Downgrade migrations are not supported ({current_version} -> {target_version}).",
            file=sys.stderr,
        )
        sys.exit(1)

    if not path and compare_versions(current_version, target_version) == 0:
        if not options.dump_sql:
            print(f"Absurd schema is already at {target_version}")
        return

    if not path and compare_versions(current_version, target_version) < 0:
        if not options.dump_sql:
            print(
                f"No migration files found between {current_version} and {target_version}; "
                "treating intermediate releases as null migrations."
            )
            print(f"Absurd schema migrated successfully to {target_version}")
        return

    if (options.verbose or options.dry_run) and not options.dump_sql:
        print(f"Migration plan ({current_version} -> {target_version}):")
        for migration in path:
            print(f"  - {migration['name']} [{migration['source']}]")

    if options.dry_run and not options.dump_sql:
        return

    resolved_steps = []
    for migration in path:
        sql_content = get_migration_sql(migration)
        resolved_steps.append(
            {
                "migration": migration,
                "sql": sql_content,
                "declares_schema_version": migration_declares_schema_version(
                    sql_content
                ),
            }
        )

    legacy_steps = [
        step["migration"]["name"]
        for step in resolved_steps
        if not step["declares_schema_version"]
    ]
    if legacy_steps and not from_version_supplied:
        print(
            "Error: Migration plan contains legacy migrations without "
            "absurd.get_schema_version() metadata.",
            file=sys.stderr,
        )
        print(
            "Please rerun with --from VERSION to explicitly confirm the "
            "starting schema version.",
            file=sys.stderr,
        )
        print("Legacy migrations in plan:", file=sys.stderr)
        for migration_name in legacy_steps:
            print(f"  - {migration_name}", file=sys.stderr)
        sys.exit(1)

    if options.dump_sql:
        print(
            render_combined_migration_sql(
                current_version,
                target_version,
                resolved_steps,
            ),
            end="",
        )
        return

    for step in resolved_steps:
        migration = step["migration"]
        sql_content = step["sql"]
        if options.verbose:
            print(f"Applying migration {migration['name']}...")
        run_psql(
            config,
            input_data=sql_content,
            error_message=f"Error applying migration {migration['name']}",
        )

        parsed = parse_migration_filename(migration["name"])
        if parsed is not None and step["declares_schema_version"]:
            _, migrated_to = parsed
            actual_version = get_recorded_schema_version(config)
            if actual_version != migrated_to:
                print(
                    f"Error: Migration {migration['name']} did not set schema version to {migrated_to} "
                    f"(got {actual_version or 'unknown'}).",
                    file=sys.stderr,
                )
                sys.exit(1)
        elif parsed is not None and options.verbose:
            print(
                f"Migration {migration['name']} does not define absurd.get_schema_version(); "
                "skipping version verification for this step."
            )

    print(f"Absurd schema migrated successfully to {target_version}")


