  absurdctl install-skill .pi/skills
"""
    )


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("help", "--help", "-h"):
        show_help()
        sys.exit(0)

    command = sys.argv[1]
    args = sys.argv[2:]

    if command == "cleanup":
        cmd_cleanup(args)
    elif command == "migrate":
        cmd_migrate(args)
    elif command == "schema-version":
        cmd_schema_version(args)
    elif command == "create-queue":
        cmd_create_queue(args)
    elif command == "queue-policy":
        cmd_queue_policy(args)
    elif command == "cron":
        cmd_cron(args)
    elif command == "list-detach-candidates":
        cmd_list_detach_candidates(args)
    elif command == "detach-candidate":
        cmd_detach_candidate(args)
    elif command == "drop-queue":
        cmd_drop_queue(args)
    elif command == "list-queues":
        cmd_list_queues(args)
    elif command == "init":
        cmd_init(args)
    elif command == "spawn-task":
        cmd_spawn_task(args)
    elif command == "retry-task":
        cmd_retry_task(args)
    elif command == "emit-event":
        cmd_emit_event(args)
    elif command == "list-tasks":
        cmd_list_tasks(args)
    elif command == "cancel-task":
        cmd_cancel_task(args)
    elif command == "dump-task":
        cmd_dump_task(args)
    elif command == "install-skill":
        cmd_install_skill(args)
    else:
        print(f"Unknown command: {command}", file=sys.stderr)
        print("")
        show_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
