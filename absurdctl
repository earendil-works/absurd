# Queue names are interpolated into generated table/index names (t_<queue>,
# r_<queue>_sai, ...). We cap UTF-8 byte length so those identifiers stay
# within PostgreSQL's 63-byte limit; character set is otherwise delegated to
# PostgreSQL quoted identifier rules.
MAX_QUEUE_NAME_LENGTH = 57


GITHUB_OWNER = "earendil-works"
GITHUB_REPO = "absurd"
GITHUB_RAW_BASE = f"https://raw.githubusercontent.com/{GITHUB_OWNER}/{GITHUB_REPO}"
