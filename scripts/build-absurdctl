#!/usr/bin/env python3
"""Build bundled absurdctl artifacts for standalone use and PyPI."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
from pathlib import Path


PROJECT_ROOT = Path(__file__).resolve().parents[1]
SOURCE = PROJECT_ROOT / "absurdctl"
STANDALONE_OUTPUT = PROJECT_ROOT / "dist" / "absurdctl"
PYPI_STAGING_DIR = PROJECT_ROOT / ".build" / "absurdctl-pypi"
SCHEMA_PATH = PROJECT_ROOT / "sql" / "absurd.sql"
MIGRATIONS_DIR = PROJECT_ROOT / "sql" / "migrations"
SKILLS_DIR = PROJECT_ROOT / "skills"
README_SOURCE = PROJECT_ROOT / "docs" / "absurdctl.md"
LICENSE_SOURCE = PROJECT_ROOT / "LICENSE"

BEGIN_MARKER = "# BEGIN BUNDLED DATA (autogenerated by scripts/build-absurdctl)"
END_MARKER = "# END BUNDLED DATA"
EXACT_TAG_VERSION_RE = re.compile(r"^v?(?P<version>[0-9]+\.[0-9]+\.[0-9]+(?:-[A-Za-z0-9.]+)?)$")
DESCRIBE_VERSION_RE = re.compile(
    r"^v?(?P<tag>[0-9]+\.[0-9]+\.[0-9]+(?:-[A-Za-z0-9.]+)?)-(?P<distance>[0-9]+)-g(?P<sha>[0-9a-f]+)(?P<dirty>-dirty)?$"
)


def detect_target_version() -> str:
    try:
        return (
            subprocess.check_output(
                ["git", "describe", "--tags", "--exact-match"],
                cwd=PROJECT_ROOT,
                text=True,
                stderr=subprocess.DEVNULL,
            )
            .strip()
            .removeprefix("v")
        )
    except subprocess.CalledProcessError:
        return "main"


def pep440_version_from_describe(describe: str) -> str:
    describe = describe.strip()

    match = EXACT_TAG_VERSION_RE.match(describe)
    if match is not None:
        return match.group("version")

    match = DESCRIBE_VERSION_RE.match(describe)
    if match is not None:
        tag = match.group("tag")
        distance = match.group("distance")
        sha = match.group("sha")
        dirty = ".dirty" if match.group("dirty") else ""
        if distance == "0" and not dirty:
            return tag
        return f"{tag}.dev{distance}+g{sha}{dirty}"

    if re.match(r"^[0-9a-f]{7,}$", describe):
        return f"0.0.0.dev0+g{describe}"

    raise RuntimeError(f"Unsupported git describe output for PyPI versioning: {describe}")


def detect_package_version() -> str:
    try:
        describe = subprocess.check_output(
            ["git", "describe", "--tags", "--long", "--dirty", "--always"],
            cwd=PROJECT_ROOT,
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
    except subprocess.CalledProcessError as exc:
        raise RuntimeError("Could not determine package version from git") from exc

    return pep440_version_from_describe(describe)


def collect_migrations() -> dict[str, str]:
    migrations: dict[str, str] = {}
    for path in sorted(MIGRATIONS_DIR.glob("*.sql")):
        migrations[path.name] = path.read_text(encoding="utf-8")
    return migrations


def collect_skills() -> dict[str, str]:
    skills: dict[str, str] = {}
    if not SKILLS_DIR.exists():
        return skills

    for path in sorted(SKILLS_DIR.rglob("*")):
        if not path.is_file():
            continue
        relative_path = path.relative_to(PROJECT_ROOT).as_posix()
        skills[relative_path] = path.read_text(encoding="utf-8")
    return skills


def render_bundle_block(
    target_version: str,
    schema_sql: str,
    migrations: dict[str, str],
    skills: dict[str, str],
) -> str:
    return "\n".join(
        [
            BEGIN_MARKER,
            f"ABSURD_SCHEMA_TARGET_VERSION = {json.dumps(target_version)}",
            f"BUNDLED_SCHEMA_SQL = {json.dumps(schema_sql)}",
            f"BUNDLED_MIGRATIONS = {json.dumps(migrations, sort_keys=True)}",
            f"BUNDLED_SKILLS = {json.dumps(skills, sort_keys=True)}",
            END_MARKER,
        ]
    )


def render_bundled_source(
    source: str,
    *,
    target_version: str,
    schema_sql: str,
    migrations: dict[str, str],
    skills: dict[str, str],
) -> str:
    if BEGIN_MARKER not in source or END_MARKER not in source:
        raise RuntimeError("Could not find bundled-data markers in absurdctl")

    bundle = render_bundle_block(target_version, schema_sql, migrations, skills)
    pattern = re.compile(
        rf"{re.escape(BEGIN_MARKER)}.*?{re.escape(END_MARKER)}",
        flags=re.DOTALL,
    )
    return pattern.sub(lambda _: bundle, source)


def render_pypi_pyproject(version: str) -> str:
    return f'''[project]
name = "absurdctl"
version = {json.dumps(version)}
description = "CLI for managing Absurd schemas, queues, tasks, and events"
readme = "README.md"
requires-python = ">=3.9"
license = "Apache-2.0"
license-files = ["LICENSE"]
keywords = ["absurd", "postgresql", "workflow", "queue", "cli"]
authors = [
    {{ name = "Armin Ronacher", email = "armin.ronacher@active-4.com" }}
]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Environment :: Console",
    "Intended Audience :: Developers",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.9",
    "Programming Language :: Python :: 3.10",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Programming Language :: Python :: 3.13",
    "Programming Language :: Python :: 3.14",
]
dependencies = []

[project.urls]
Homepage = "https://github.com/earendil-works/absurd"
Documentation = "https://github.com/earendil-works/absurd/blob/main/docs/absurdctl.md"
Repository = "https://github.com/earendil-works/absurd"
Issues = "https://github.com/earendil-works/absurd/issues"
Changelog = "https://github.com/earendil-works/absurd/blob/main/CHANGELOG.md"

[project.scripts]
absurdctl = "absurdctl:main"

[build-system]
requires = ["uv_build>=0.10.0,<0.11.0"]
build-backend = "uv_build"

[tool.uv.build-backend]
module-name = "absurdctl"
module-root = ""
source-include = ["README.md", "LICENSE"]
'''


def write_standalone_bundle(rendered_source: str, output_path: Path = STANDALONE_OUTPUT) -> Path:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(rendered_source, encoding="utf-8")
    os.chmod(output_path, 0o755)
    return output_path


def write_pypi_staging(
    rendered_source: str,
    version: str,
    output_dir: Path = PYPI_STAGING_DIR,
    *,
    readme_text: str | None = None,
    license_text: str | None = None,
) -> Path:
    shutil.rmtree(output_dir, ignore_errors=True)
    output_dir.mkdir(parents=True, exist_ok=True)

    if readme_text is None:
        readme_text = README_SOURCE.read_text(encoding="utf-8")
    if license_text is None:
        license_text = LICENSE_SOURCE.read_text(encoding="utf-8")

    package_dir = output_dir / "absurdctl"
    package_dir.mkdir(parents=True, exist_ok=True)
    (package_dir / "__init__.py").write_text(rendered_source, encoding="utf-8")
    (output_dir / "pyproject.toml").write_text(
        render_pypi_pyproject(version), encoding="utf-8"
    )
    (output_dir / "README.md").write_text(readme_text, encoding="utf-8")
    (output_dir / "LICENSE").write_text(license_text, encoding="utf-8")
    return output_dir


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Build bundled absurdctl artifacts for standalone release and PyPI."
    )
    parser.add_argument(
        "--standalone-only",
        action="store_true",
        help="Only build the standalone dist/absurdctl artifact.",
    )
    parser.add_argument(
        "--pypi-only",
        action="store_true",
        help="Only build the PyPI staging directory.",
    )
    args = parser.parse_args()

    if args.standalone_only and args.pypi_only:
        parser.error("--standalone-only and --pypi-only are mutually exclusive")

    return args


def main() -> None:
    args = parse_args()
    build_standalone = not args.pypi_only
    build_pypi = not args.standalone_only

    source = SOURCE.read_text(encoding="utf-8")
    target_version = detect_target_version()
    package_version = None
    schema_sql = SCHEMA_PATH.read_text(encoding="utf-8")
    migrations = collect_migrations()
    skills = collect_skills()
    rendered = render_bundled_source(
        source,
        target_version=target_version,
        schema_sql=schema_sql,
        migrations=migrations,
        skills=skills,
    )

    if build_standalone:
        standalone_path = write_standalone_bundle(rendered)
        print(f"Wrote standalone bundle: {standalone_path}")

    if build_pypi:
        package_version = detect_package_version()
        staging_dir = write_pypi_staging(rendered, package_version)
        print(f"Wrote PyPI staging directory: {staging_dir}")
        print(f"PyPI package version: {package_version}")

    print(f"Embedded target version: {target_version}")
    print(f"Embedded migrations: {len(migrations)}")
    print(f"Embedded skill files: {len(skills)}")


if __name__ == "__main__":
    main()
